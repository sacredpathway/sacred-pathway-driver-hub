# Secrets that the Edge Functions need at runtime.
# Set them on the deployed project with:
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set OPENAI_VISION_MODEL=gpt-4o
#   supabase secrets set OPENAI_TEXT_MODEL=gpt-4o-mini
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the Supabase runtime — no need to set them yourself.
#
# This file is a template. Copy to `.env` for local `supabase functions serve`
# development and NEVER commit the real `.env`.

OPENAI_API_KEY=sk-your-real-key
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o-mini
