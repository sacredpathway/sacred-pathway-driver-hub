# Driver Hub Web — local dev environment template.
#
# Copy to `.env.local` for local development; production values live in
# Cloudflare Pages → Project → Settings → Environment Variables. Both
# variables MUST also be set as production-environment vars in CF.
#
# DO NOT put the service-role key here. Web ONLY uses the anon key; RLS
# enforces per-user data isolation.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PUBLIC_ANON_KEY_HERE

# Optional — only used for the dev sign-in redirect. In production the
# Supabase project should have the live URL listed under
# Authentication → URL Configuration → Redirect URLs:
#   https://app.sacredpathway.org/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000
